{
  "id": "accounts",
  "version": "1.0.0",
  "name": "User Accounts & Sign-in",
  "keywords": ["account", "user", "password", "pin", "sign in", "login", "microsoft account", "local account", "lock screen", "forgot password"],
  "direct_commands": {
    "open accounts": "Start-Process ms-settings:accounts",
    "open account settings": "Start-Process ms-settings:accounts",
    "open sign in": "Start-Process ms-settings:signinoptions",
    "open login options": "Start-Process ms-settings:signinoptions",
    "change password": "Start-Process ms-settings:signinoptions",
    "change pin": "Start-Process ms-settings:signinoptions",
    "open lock screen": "Start-Process ms-settings:lockscreen"
  },
  "launch": {
    "accounts": "Start-Process ms-settings:accounts",
    "signin": "Start-Process ms-settings:signinoptions",
    "lockscreen": "Start-Process ms-settings:lockscreen",
    "email": "Start-Process ms-settings:emailandaccounts"
  },
  "diagnostics": [
    "Get-LocalUser | Select-Object Name,Enabled,LastLogon | Format-Table",
    "whoami /all | Select-String -Pattern 'User Name|Group Name' | Select-Object -First 5"
  ],
  "prompt": "You are helping with user account issues. Can open account settings, sign-in options (PIN, password, biometrics), lock screen settings. Common tasks: change password/PIN via Settings → Accounts → Sign-in options. For Microsoft account issues: open Settings → Accounts. For local account creation: Settings → Accounts → Family & other users."
}

{
  "id": "network",
  "name": "Network & Internet",
  "keywords": ["dns", "wifi", "internet", "network", "ip address", "vpn", "proxy", "ethernet", "connection", "ping", "slow internet", "no internet", "firewall"],
  "launch": {
    "wifi": "Start-Process ms-settings:network-wifi",
    "ethernet": "Start-Process ms-settings:network-ethernet",
    "vpn": "Start-Process ms-settings:network-vpn",
    "proxy": "Start-Process ms-settings:network-proxy",
    "status": "Start-Process ms-settings:network-status",
    "firewall": "Start-Process wf.msc"
  },
  "diagnostics": [
    "Test-NetConnection -ComputerName google.com -Port 443",
    "Get-DnsClientCache | Select-Object -First 10 Entry,Data",
    "Get-NetIPAddress | Where-Object {$_.AddressFamily -eq 'IPv4'} | Select-Object InterfaceAlias,IPAddress",
    "Get-NetAdapter | Select-Object Name,Status,LinkSpeed"
  ],
  "prompt": "You are helping with network/internet issues. You can open network settings, run diagnostics, and guide DNS changes. For DNS: open Wi-Fi properties → Edit DNS → Manual → enter preferred/alternate DNS. Common DNS: Cloudflare 1.1.1.1/1.0.0.1, Google 8.8.8.8/8.8.4.4. For connectivity: run Test-NetConnection first to diagnose."
}
